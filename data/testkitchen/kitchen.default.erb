---
driver:
  name: vagrant
  customize:
    memory: 1024

provisioner:
  name: chef_zero
  require_chef_omnibus: latest

platforms:
  - name: centos-5.10
    driver_config:
      box: centos-5.10-min-x86_64
  - name: centos-6.4
    driver_config:
      box: centos-6.5-x86_64
suites:
  - name: default
    run_list:
      - recipe[<%= @cookbook %>::default]
    attributes:
